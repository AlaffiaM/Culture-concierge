PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/appName

# Gemini AI (primary LLM for itinerary generation and tag suggestions)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary (image uploads — not yet active)
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=123456
CLOUDINARY_API_SECRET=your_secret

# Make.com webhook secret
MAKE_WEBHOOK_SECRET=https://hook.eu1.make.com/...

# Outscraper API key (Google Maps photos — sign up at https://outscraper.com)
OUTSCRAPER_API_KEY=your_api_key_here

# Admin auth (comma-separated emails — same list as frontend)
ADMIN_EMAILS=you@example.com,other@example.com
